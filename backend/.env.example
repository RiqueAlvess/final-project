# Django
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True
DJANGO_SETTINGS_MODULE=config.settings.development
ALLOWED_HOSTS=localhost,127.0.0.1,*.sistema.com

# ─── Supabase ──────────────────────────────────────────────────────────────────
# Find these values in your Supabase project:
#   Settings → API  →  URL / anon key / service_role key
#   Settings → Database → Connection string (Session mode, port 5432)
#
# IMPORTANT: use the Session Pooler (port 5432), NOT the Transaction Pooler
# (port 6543) — django-tenants is incompatible with transaction-mode pooling.

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_STORAGE_BUCKET=media

# ─── Database (Supabase PostgreSQL — Session Pooler) ──────────────────────────
# Format: postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql://postgres.your-project-ref:your-password@aws-0-us-east-1.pooler.supabase.com:5432/postgres

# Enable SSL for Supabase connections (set True in production)
DB_SSL_REQUIRE=False

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── JWT ───────────────────────────────────────────────────────────────────────
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=15
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ─── CORS ──────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ─── Email / Resend ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_your_resend_api_key_here
DEFAULT_FROM_EMAIL=noreply@yourdomain.com
FRONTEND_URL=http://localhost:3000

# ─── Security ──────────────────────────────────────────────────────────────────
PASSWORD_RESET_TOKEN_EXPIRY_HOURS=24
